<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- INTERNET -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- FOTOS -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".ui.Arquitetura.Hilt.ClasseDeAplicacao.ClasseDeAplicacao"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_canivete"
        android:label="@string/appName"
        android:roundIcon="@drawable/ic_canivete"
        android:supportsRtl="true"
        android:theme="@style/Theme.KotlinCaniveteSuico"
        tools:targetApi="31">

        <activity
            android:name=".ui.Git.Main.GitActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Compose.View.Atributos.ComposeAtributos"
            android:exported="false"
            android:label="@string/COMPOSE_ATRIBUTOS"
            android:theme="@style/Theme.KotlinCaniveteSuico" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/appName"
            android:theme="@style/Theme.KotlinCaniveteSuico.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>