<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="408dp"
        android:layout_height="83dp"
        android:background="@android:color/holo_green_light"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="TODO"
        tools:ignore="ContentDescription,HardcodedText" />

    <TextView
        android:id="@+id/id_textView_toast_1"
        android:layout_width="107dp"
        android:layout_height="31dp"
        android:layout_marginTop="12dp"
        android:drawableStart="@android:drawable/checkbox_on_background"
        android:text="   Sucesso"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/imageView"
        tools:ignore="HardcodedText,TextSizeCheck,UseCompatTextViewDrawableXml" />

    <TextView
        android:id="@+id/id_textView_toast_2"
        android:layout_width="301dp"
        android:layout_height="40dp"
        android:layout_marginTop="52dp"
        android:drawableStart="@android:drawable/checkbox_on_background"
        android:text="Todas as informacoes foram salvas"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/imageView"
        tools:ignore="HardcodedText,TextSizeCheck,UseCompatTextViewDrawableXml" />

</androidx.constraintlayout.widget.ConstraintLayout>